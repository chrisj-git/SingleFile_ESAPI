<Window x:Class="TargetOverlap.OverlapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TargetOverlap"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="350"
             Height="500" Width="350"
             Title="Structure Overlap Calculator">
    <Grid>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
            <Label Content="Select the structure to compute overlaps with:" FontSize="14" FontWeight="Bold" />
            <ComboBox x:Name="Structures_comboBox" Width="200" Margin="10"/>
            <Button Content="Calculate" Width="75" Margin="5" Click="Button_Click"/>
            <DataGrid x:Name="Result_DataGrid" ItemsSource="{Binding Overlaps}" Margin="10" HorizontalScrollBarVisibility="Disabled"/>
        </StackPanel>
    </Grid>
</Window>
