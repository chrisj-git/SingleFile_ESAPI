<Window x:Class="TargetOverlap.OverlapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TargetOverlap"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="350"
             Height="500" Width="350"
             Title="Structure Overlap Calculator">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Select the structure to compute overlaps with:" FontSize="14" FontWeight="Bold"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" x:Name="Structures_comboBox" Height="25" Margin="10" HorizontalAlignment="Center" HorizontalContentAlignment="Left"/>
        <Button Grid.Row="2" Content="Calculate" Width="80" Height="30" Margin="5" Click="Button_Click" HorizontalAlignment="Center"/>

        <DataGrid Grid.Row="3" x:Name="Result_DataGrid" ItemsSource="{Binding Overlaps}" Margin="10" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Structure" Binding="{Binding Structure}" Width="*" />
                <DataGridTextColumn Header="OverlapFraction" Binding="{Binding OverlapFraction}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
