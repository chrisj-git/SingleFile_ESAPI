<Window x:Class="TargetOverlap.SelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TargetOverlap"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="400"
             Height="250" Width="400"
             Title="Structure Selection">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Select the structure to compute overlaps with:" FontSize="14" FontWeight="Bold" />
            <ComboBox x:Name="Structures_comboBox" Width="250" Margin="10"/>
            <Button Content="OK" Width="75" Margin="5" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>
